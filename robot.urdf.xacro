<?xml version="1.0"?>
<robot name="diff_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="use_ros2_control" default="false"/>
  <xacro:arg name="controllers_file" default="controllers.yaml"/>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.30 0.20 0.10"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.30 0.20 0.10"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.020" ixy="0.0" ixz="0.0" iyy="0.040" iyz="0.0" izz="0.050"/>
    </inertial>
  </link>

  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0.0 0.10 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0.0 -0.10 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <gazebo reference="base_link">
    <material>Gazebo/Gray</material>
  </gazebo>

  <xacro:if value="$(arg use_ros2_control)">
    <xacro:include filename="ros2_control.xacro"/>
    <xacro:ros2_control_system
      left_wheel_joint="left_wheel_joint"
      right_wheel_joint="right_wheel_joint"
      controllers_file="$(arg controllers_file)"/>
  </xacro:if>

  <xacro:unless value="$(arg use_ros2_control)">
    <xacro:include filename="gz_control.xacro"/>
    <xacro:gz_diff_drive
      left_wheel_joint="left_wheel_joint"
      right_wheel_joint="right_wheel_joint"
      odom_frame="odom"
      base_frame="base_link"/>
  </xacro:unless>
</robot>
